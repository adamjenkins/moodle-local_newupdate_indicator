{{!
    @template local_newupdate_indicator/recentlist

    A short list of newly added or recently updated course content.

    Example context (json):
    {
        "title": "New and recently updated",
        "items": [
            {
                "cmid": 12,
                "name": "Week 3 quiz",
                "url": "https://example.com/mod/quiz/view.php?id=12",
                "status": "new",
                "colour": "success",
                "label": "New",
                "iconhtml": "<i class=\"icon\"></i>"
            }
        ]
    }
}}
<div class="local-newupdate-indicator-list card mb-3" data-region="local-newupdate-indicator-list">
    <div class="card-body">
        <h3 class="card-title h5">{{title}}</h3>
        <ul class="list-unstyled mb-0">
            {{#items}}
                <li class="local-newupdate-indicator-list-item d-flex align-items-center mb-1">
                    <span class="local-newupdate-indicator local-newupdate-indicator-{{status}} local-newupdate-indicator-colour-{{colour}} local-newupdate-indicator-pos-inline me-2">
                        {{#iconhtml}}
                            <span class="local-newupdate-indicator-icon">{{{iconhtml}}}</span>
                        {{/iconhtml}}
                        <span class="local-newupdate-indicator-label">{{label}}</span>
                    </span>
                    {{#url}}
                        <a href="{{url}}">{{name}}</a>
                    {{/url}}
                    {{^url}}
                        <span>{{name}}</span>
                    {{/url}}
                </li>
            {{/items}}
        </ul>
    </div>
</div>
